<!DOCTYPE html>
html(lang='uk')
head
  meta(charset='utf-8')
  meta(name='viewport', content='width=device-width, initial-scale=1.0')
  title Колиби на базі відпочинку «Альбатрос» у селі Воля-Гомулецька
  meta(name='description', content='Невеликі затишні колиби на чотирьох чоловік.')
  link(rel='shortcut icon', href='favicon.ico', type='image/x-icon')
  // Open Graph Tags
  meta(property='og:title', content='Колиби на базі відпочинку «Альбатрос»')
  meta(property='og:description', content='Невеликі затишні колиби на чотирьох чоловік.')
  meta(property='og:site_name', content='Albatroz.lviv.ua')
  meta(property='og:url', content='http://albatroz.lviv.ua')
  meta(property='og:image', content='http://albatroz.lviv.ua/images/slide-one.jpg')
  meta(property='og:type', content='place')
  meta(property='og:locale', content='uk_UA')
  // Tweeter Card Tags
  meta(name='twitter:card', content='summary_large_image')
  meta(name='twitter:title', content='Колиби на базі відпочинку «Альбатрос»')
  meta(name='twitter:description', content='Невеликі затишні колиби на чотирьох чоловік.')
  meta(name='twitter:image', content='http://albatroz.lviv.ua/images/slide-one.jpg')
  // Links
  link(rel='stylesheet', type='text/css', href='https://stackpath.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css')
  link(href='styles/custom.css', media='screen', rel='stylesheet', type='text/css')
  link(href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.6.3/css/font-awesome.min.css' rel='stylesheet')
  link(href='https://cdnjs.cloudflare.com/ajax/libs/lightgallery/1.2.19/css/lightgallery.min.css' rel='stylesheet')
  body
    include ./partials/navbar.jade

    div.container
      div.row#slider
        div.col-md-12
          img.img-responsive.img-rounded(src="images/slide-four.jpg" alt="Main Logo")

      div.row#service
        div.col-md-5
          h2 Колиби
          blockquote.blockquote
            p Хочете заночувати великою компанією та по більш низькій ціні - значить вам потрібна колиба. Наші колиби розраховані на 4х чоловік. У вартість також входить набор постілі та накритий столик з мангалом біля самої колиби. 
            p Вартість колиби - <b>400</b> грн./добу

        div.col-md-7
          div.demo-gallery
            ul#lightgallery
              li(data-src='images/medium/kol-1-md.jpg', data-sub-html='<p>на території комплексу розташовано 4 колиби</p>')
                a(href='')
                  img.img-responsive(src='images/thumbs/kol-1-thumb.jpg')
                  .demo-gallery-poster
                    img(src='images/zoom.png')
              li(data-src='images/medium/kol-2-md.jpg', data-sub-html='<p></p>')
                a(href='')
                  img.img-responsive(src='images/thumbs/kol-2-thumb.jpg')
                  .demo-gallery-poster
                    img(src='images/zoom.png')
              li(data-src='images/medium/kol-3-md.jpg', data-sub-html='<p></p>')
                a(href='')
                  img.img-responsive(src='images/thumbs/kol-3-thumb.jpg')
                  .demo-gallery-poster
                    img(src='images/zoom.png')
              li(data-src='images/medium/kol-4-md.jpg', data-sub-html='<p>при оренді колиби - безкоштовно столик з мангалом</p>')
                a(href='')
                  img.img-responsive(src='images/thumbs/kol-4-thumb.jpg')
                  .demo-gallery-poster
                    img(src='images/zoom.png')
              li(data-src='images/medium/kol-6-md.jpg', data-sub-html='<p></p>')
                a(href='')
                  img.img-responsive(src='images/thumbs/kol-6-thumb.jpg')
                  .demo-gallery-poster
                    img(src='images/zoom.png')
              li(data-src='images/medium/kol-8-md.jpg', data-sub-html='<p></p>')
                a(href='')
                  img.img-responsive(src='images/thumbs/kol-8-thumb.jpg')
                  .demo-gallery-poster
                    img(src='images/zoom.png')

    include ./partials/footer.jade
