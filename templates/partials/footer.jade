div.container
  div.row#contacts
    div.col-md-6.contact-info
      div.info-detail
        ul
          li
            h3 КОНТАКТИ
          li
            i.fa.fa-calendar
            span <b>Понеділок - Неділя:</b>
              |  з 8:00 до 23:00
          li
            i.fa.fa-map-marker
            span <b>Адреса:</b>
            |  Львівська обл., Жовківський р-н.,
          li
