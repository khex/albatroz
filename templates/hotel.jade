<!DOCTYPE html>
html(lang='uk')
head
  meta(charset='utf-8')
  meta(name='viewport', content='width=device-width, initial-scale=1.0')
  title Готель на базі відпочинку «Альбатрос» у селі Воля-Гомулецька
  meta(name='description', content='Невеликий готель на дев\'ять двомісних номерів.')
  link(rel='shortcut icon', href='favicon.ico', type='image/x-icon')
  // Open Graph Tags
  meta(property='og:title', content='Готель на базі відпочинку «Альбатрос»')
  meta(property='og:description', content='Невеликий готель на дев\'ять двомісних номерів.')
  meta(property='og:site_name', content='Albatroz.lviv.ua')
  meta(property='og:url', content='http://albatroz.lviv.ua')
  meta(property='og:image', content='http://albatroz.lviv.ua/images/slide-one.jpg')
  meta(property='og:type', content='place')
  meta(property='og:locale', content='uk_UA')
  // Tweeter Card Tags
  meta(name='twitter:card', content='summary_large_image')
  meta(name='twitter:title', content='Готель на базі відпочинку «Альбатрос»')
  meta(name='twitter:description', content='Невеликий готель на дев\'ять двомісних номерів.')
  meta(name='twitter:image', content='http://albatroz.lviv.ua/images/slide-one.jpg')
  // Links
  link(rel='stylesheet', type='text/css', href='https://stackpath.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css')
  link(href='styles/custom.css', media='screen', rel='stylesheet', type='text/css')
  link(href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.6.3/css/font-awesome.min.css' rel='stylesheet')
  link(href='https://cdnjs.cloudflare.com/ajax/libs/lightgallery/1.2.19/css/lightgallery.min.css' rel='stylesheet')
  body
    include ./partials/navbar.jade
    div.container
      div.row#slider
        div.col-md-12
          img.img-responsive.img-rounded(src="images/slide-four.jpg" alt="Main Logo")

      div.row#service
        div.col-md-5
          h2 Готель
          blockquote.blockquote
            p Невеликий готель на дев'ять двомісних номерів. В номерах є все необхідне для комфортного проживання - журнальний столик, шафа для одягу, телевізор, туалет із душем, а з вікна відкривається краєвид на озеро. У вартість номера входить постіль та рушник.
            p Вартість за номер - 350 грн./доба

        div.col-md-7
          div.demo-gallery
            ul#lightgallery
              li(data-src='images/medium/hot-3-md.jpg', data-sub-html='<p>хол 2го поверху</p>')
                a(href='')
                  img.img-responsive(src='images/thumbs/hot-3-thumb.jpg')
                  .demo-gallery-poster
                    img(src='images/zoom.png')
              li(data-src='images/medium/hot-4-md.jpg', data-sub-html='<p>фото номера</p>')
                a(href='')
                  img.img-responsive(src='images/thumbs/hot-4-thumb.jpg')
                  .demo-gallery-poster
                    img(src='images/zoom.png')
              li(data-src='images/medium/hot-5-md.jpg', data-sub-html='<p>фото номера</p>')
                a(href='')
                  img.img-responsive(src='images/thumbs/hot-5-thumb.jpg')
                  .demo-gallery-poster
                    img(src='images/zoom.png')
              li(data-src='images/medium/hot-6-md.jpg', data-sub-html='<p>фото номера</p>')
                a(href='')
                  img.img-responsive(src='images/thumbs/hot-6-thumb.jpg')
                  .demo-gallery-poster
                    img(src='images/zoom.png')
              li(data-src='images/medium/hot-7-md.jpg', data-sub-html='<p>душова кімната в номері</p>')
                a(href='')
                  img.img-responsive(src='images/thumbs/hot-7-thumb.jpg')
                  .demo-gallery-poster
                    img(src='images/zoom.png')
              li(data-src='images/medium/hot-8-md.jpg', data-sub-html='<p>вид з вікна номера</p>')
                a(href='')
                  img.img-responsive(src='images/thumbs/hot-8-thumb.jpg')
                  .demo-gallery-poster
                    img(src='images/zoom.png')

    include ./partials/footer.jade
