<!DOCTYPE html>
html(lang='uk')
  include ./partials/head.jade
  body
    include ./partials/navbar.jade

    div.container
      div.row#slider
        div.col-md-12
          img.img-responsive.img-rounded(src="images/slide-four.jpg" alt="Main Logo")

      div.row#service
        div.col-md-5
          h2 Столики
          blockquote.blockquote
            p Загалом на нашій базі знаходиться 24 столика на 10, 20 та 30 чоловік. Всі вони мають дашок, котрий захиститьВас та вашу компанію від палючого сонця вдень та від дощу у непогоду, та мангал. Обирайте самі місце відпочинку - у затінку на берегу озера чи на відкритій сонячній галявні. 
            p Вартість будь-якого столика - <b>300</b> грн.
            p Вартість в'язки дров - <b>50</b> грн.

        div.col-md-7
          div.demo-gallery
            ul#lightgallery
              li(data-src='images/medium/mag-2-md.jpg', data-sub-html='<p>цетральний столик на 30 осіб</p>')
                a(href='')
                  img.img-responsive(src='images/thumbs/tab-2-thumb.jpg')
                  .demo-gallery-poster
                    img(src='images/zoom.png')
              li(data-src='images/medium/mag-3-md.jpg', data-sub-html='<p>столик на 20 чоловік</p>')
                a(href='')
                  img.img-responsive(src='images/thumbs/tab-3-thumb.jpg')
                  .demo-gallery-poster
                    img(src='images/zoom.png')
              li(data-src='images/medium/mag-4-md.jpg', data-sub-html='<p>столик на 10 чоловік</p>')
                a(href='')
                  img.img-responsive(src='images/thumbs/tab-4-thumb.jpg')
                  .demo-gallery-poster
                    img(src='images/zoom.png')
              li(data-src='images/medium/mag-5-md.jpg', data-sub-html='<p>на території комплексу розташовано 24 столики</p>')
                a(href='')
                  img.img-responsive(src='images/thumbs/tab-5-thumb.jpg')
                  .demo-gallery-poster
                    img(src='images/zoom.png')
              li(data-src='images/medium/mag-6-md.jpg', data-sub-html='<p>столик на 20 чоловік</p>')
                a(href='')
                  img.img-responsive(src='images/thumbs/tab-6-thumb.jpg')
                  .demo-gallery-poster
                    img(src='images/zoom.png')
              li(data-src='images/medium/mag-7-md.jpg', data-sub-html='<p>столик на 20 чоловік</p>')
                a(href='')
                  img.img-responsive(src='images/thumbs/tab-7-thumb.jpg')
                  .demo-gallery-poster
                    img(src='images/zoom.png')

    include ./partials/footer.jade
